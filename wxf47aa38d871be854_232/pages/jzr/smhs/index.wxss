.container {
    box-sizing: border-box;
    padding-bottom: 140rpx;
}

.header {
    align-items: center;
    background: #14c79d;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 400rpx;
    justify-content: center;
}

.header .login-photo {
    border: 1px solid #fff;
    border-radius: 50%;
    height: 144rpx;
    overflow: hidden;
    width: 144rpx;
}

.header .txt_1 {
    color: #fff;
    font-size: 30rpx;
    line-height: 1;
    padding-top: 30rpx;
}

.header .txt_2 {
    color: #fff;
    font-size: 24rpx;
    line-height: 1;
    padding-top: 20rpx;
}

.wrap {
    background: #fff;
    border-radius: 10rpx;
    margin: -20rpx 24rpx 40rpx;
    padding: 0 30rpx;
}

.wrap .row {
    border-bottom: 1px solid #ebebeb;
    padding: 30rpx 0;
}

.wrap .row:last-child {
    border-bottom: none;
}

.wrap .row .r_txt {
    font-size: 28rpx;
}

.wrap .row input {
    font-size: 34rpx;
    padding: 10rpx 0;
}

.wrap .row .place-color {
    color: #999;
}

.check-box,.wrap .row_select {
    display: -webkit-flex;
    display: flex;
}

.check-box {
    align-items: center;
    background: #fafafa;
    border: 1px solid #b0b1b5;
    border-radius: 50%;
    height: 36rpx;
    justify-content: center;
    margin-right: 20rpx;
    width: 36rpx;
}

.check-box.selected {
    background: #14c79d;
    border: 1px solid #14c79d;
}

.check-box .check {
    background: #fafafa;
    border-radius: 50%;
    height: 20rpx;
    margin: auto;
    width: 20rpx;
}

.r_tips {
    padding-top: 4rpx;
}

.r_tips .tips_txt_1 {
    font-size: 32rpx;
    line-height: 1;
}

.r_tips .tips_txt_2 {
    color: #999;
    font-size: 28rpx;
    line-height: 1;
    margin-top: 20rpx;
}

.btn {
    background: #14c79d;
    border-radius: 10rpx;
    color: #fff;
    font-size: 34rpx;
    line-height: 90rpx;
    margin: 100rpx auto 0;
    width: calc(100% - 48rpx);
}

.btn,.spz {
    text-align: center;
}

.spz {
    color: #14c79d;
    font-size: 28rpx;
    font-weight: 500;
    line-height: 47rpx;
    margin-top: 100rpx;
    text-decoration: underline;
}

