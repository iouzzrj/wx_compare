page {
    box-sizing: border-box;
    padding: 20rpx 24rpx;
}

.item {
    background: #fff;
    margin-bottom: 20rpx;
}

.item .i-top {
    height: 110rpx;
    padding: 0 30rpx;
}

.item .i-top .block {
    background: #14c79d;
    height: 36rpx;
    margin-right: 30rpx;
    width: 6rpx;
}

.item .i-top .name {
    font-size: 34rpx;
    margin-right: 18rpx;
}

.item .i-top .txt_box {
    border: 2rpx solid #ff625b;
    border-radius: 7rpx;
    color: #ff625b;
    font-size: 26rpx;
    height: 32rpx;
    line-height: 32rpx;
    text-align: center;
    width: 70rpx;
}

.item .i-top .t-right {
    border: 2rpx solid #14c79d;
    border-radius: 7rpx;
    color: #14c79d;
    font-size: 28rpx;
    height: 46rpx;
    line-height: 46rpx;
    text-align: center;
    width: 136rpx;
}

.item .i-top .t-right image {
    height: 47rpx;
    padding: 0 20rpx;
    width: 11rpx;
}

.t-right-create {
    border: 2rpx solid #14c79d;
    border-radius: 7rpx;
    color: #14c79d;
    font-size: 28rpx;
    height: 46rpx;
    line-height: 46rpx;
    text-align: center;
    width: 150rpx;
}

.item .i-top .t-right-create image {
    height: 47rpx;
    padding: 0 20rpx;
    width: 11rpx;
}

.item .info .row {
    align-items: center;
    border-top: 1rpx solid #f0f1f1;
    display: -webkit-flex;
    display: flex;
    padding: 0 30rpx;
}

.item .info .row:nth-child(1) {
    height: 160rpx;
}

.item .info .row.radio-box {
    padding-bottom: 20rpx;
    padding-top: 20rpx;
}

.l-style {
    background: #ccc;
    height: 40rpx;
    position: relative;
    width: 4rpx;
}

.l-style .hollow {
    border-radius: 50%;
    height: 14rpx;
    width: 14rpx;
}

.l-style .top {
    border: 4rpx solid #ff625b;
    left: -8rpx;
    position: absolute;
    top: -22rpx;
}

.l-style .bottom {
    border: 4rpx solid #22a7f3;
    bottom: -22rpx;
    left: -8rpx;
    position: absolute;
}

.item .info .row:nth-child(1) .number {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    margin-left: 26rpx;
}

.item .info .row:nth-child(1) .number text {
    color: #999;
    line-height: 56rpx;
}

.footer {
    background: #fff;
    height: 90rpx;
    padding: 0 24rpx;
}

.footer .f-left text:first-child {
    color: #14c79d;
    font-size: 48rpx;
}

.footer .f-left text:last-child {
    color: #999;
    font-size: 32rpx;
    margin-left: 10rpx;
}

.footer .f-right text {
    color: #ff625b;
    font-size: 28rpx;
}

.footer .f-right image {
    height: 15rpx;
    margin-left: 10rpx;
    transform: rotate(90deg);
    width: 23rpx;
}

