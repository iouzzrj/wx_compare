page {
    background: #fff!important;
}

.result_wrap {
    margin-top: 0;
    padding: 0 20rpx;
}

.result_wrap .result {
    margin: 80rpx 0;
    text-align: center;
}

.result_wrap .result .title,.result_wrap .result icon {
    display: block;
    margin: 20rpx 0;
}

.result_wrap .result .title {
    color: #404040;
    font-size: 38rpx;
    text-align: center;
}

.result_wrap .result .sub_title {
    display: block;
    font-size: 30rpx;
}

.result_wrap .result .sub_title.success {
    color: #999;
    text-align: center;
}

.result_wrap .result .sub_title.fail {
    color: #f87259;
}

.result_wrap .result_list {
    padding-bottom: 20rpx;
}

.result_wrap .result_list .result_item {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    flex-direction: row;
    justify-content: center;
    padding-top: 20rpx;
}

.result_wrap .result_list .result_item text {
    word-wrap: normal;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.result_wrap .result_list .result_item text:nth-child(1) {
    color: #999;
    font-size: 30rpx;
    width: 200rpx;
}

.result_wrap .result_list .result_item text:nth-child(2) {
    color: var(--themeColor);
    flex: 1;
    font-size: 30rpx;
    text-align: right;
}

.result_wrap .result_list .result_item.mark_item {
    border-bottom: 1rpx solid #f2f2f2;
    padding-bottom: 20rpx;
}

.result_wrap .result_list .result_item.mark_item text:nth-child(2) {
    color: #f87259;
}

.option_wrap {
    margin-top: 15rpx;
    padding: 0 20rpx;
}

.value_text1 {
    color: var(--themeColor);
}

.btn {
    background: var(--themeColor);
    border-radius: 47rpx!important;
    color: #fff;
    font-size: 30rpx;
    font-weight: 400!important;
    height: 94rpx;
    line-height: 94rpx;
    margin-top: 20rpx;
    width: 630rpx!important;
}

