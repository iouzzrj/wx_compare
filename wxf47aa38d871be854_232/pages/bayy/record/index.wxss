page {
    box-sizing: border-box;
}

.oBody {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 80vh;
    width: 100%;
}

.bodyList {
    flex: 1;
    height: 100vh;
    overflow: hidden;
    z-index: 9;
}

.navtops {
    position: fixed;
    top: 0;
    z-index: 999;
}

.lineas {
    height: 94rpx;
}

.page .item {
    background: #fff;
    margin-bottom: 20rpx;
    margin-left: 24rpx;
    margin-right: 24rpx;
}

.page .body-first-item {
    margin-top: 20rpx;
}

.page .item .top {
    align-items: center;
    border-bottom: 5rpx dashed #f0f5f4;
    display: -webkit-flex;
    display: flex;
    height: 100rpx;
    justify-content: space-between;
    padding: 0 30rpx;
    position: relative;
}

.top .top-text {
    font-size: 32rpx;
}

.green {
    color: #14c79d;
}

.red {
    color: #ff625b;
}

.gray {
    color: #999;
}

.round {
    background: #f0f5f4;
    border-radius: 50%;
    height: 26rpx;
    position: absolute;
    width: 26rpx;
}

.r-left {
    bottom: -13rpx;
    left: -13rpx;
}

.r-right {
    bottom: -13rpx;
    right: -13rpx;
}

.item .middle {
    border-bottom: 1rpx solid #ebebeb;
    flex-direction: column;
    height: 270rpx;
    justify-content: center;
    padding: 0 30rpx;
}

.header,.item .middle {
    display: -webkit-flex;
    display: flex;
}

.header {
    align-items: center;
    background: #fff;
    box-shadow: 1 -1px 3px rgba(0,0,0,.1);
    color: #3c3c3c;
    font-size: 30rpx;
    height: 110rpx;
    justify-content: space-between;
    width: 100%;
}

.item .middle .middle-view {
    margin-bottom: 20rpx;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

.item .middle .middle-view .middle-view-text {
    color: #4c4c4c;
    margin-right: 20rpx;
}

.item .middle .middle-view .middle-view-last-text {
    color: #999;
}

.item .foot {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    height: 100rpx;
    justify-content: space-between;
    padding: 0 30rpx;
}

.item .foot .foot-first-text {
    color: #ff625b;
    font-size: 36rpx;
}

.item .foot .check,.item .foot .edit {
    color: #14c79d;
    line-height: 52rpx;
    right: 60rpx;
    text-align: center;
    width: 140rpx;
}

.item .foot .check {
    position: absolute;
}

.flex1 {
    padding: 20rpx 20rpx 20rpx 0;
    text-align: end;
}

.left {
    background: #fff;
    border: 1px solid #b3b3b3;
    border-radius: 36rpx;
    color: #000;
}

.left,.left2 {
    display: inline-block;
    height: 60rpx;
    line-height: 60rpx;
    text-align: center;
    width: 200rpx;
}

.left2 {
    background: #1cb56e;
    border-radius: 36rpx;
    color: #fff;
}

.content-Box {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
}

.mask {
    background: #000;
    bottom: 0;
    left: 0;
    opacity: .4;
    position: fixed;
    right: 0;
    top: 0;
    transition: all .2s;
    z-index: 10;
}

.pup {
    position: absolute;
    width: 620rpx;
}

.pup,.pup1 {
    background: #fff;
    border-radius: 8rpx;
    left: 50%;
    overflow: hidden;
    top: 50%;
    transform: translate(-50%,-50%);
    transition: all .5s;
    z-index: 11;
}

.pup1 {
    position: fixed;
    width: 470rpx;
}

.pup_title {
    color: var(--jc_text_one);
    font-size: 36rpx;
    margin: 30rpx 0 20rpx;
    text-align: center;
}

.l_box {
    height: 29vh;
}

.l_box,.l_box1 {
    color: #495058;
    font-size: 28rpx;
    margin-left: 8vw;
    margin-top: 3vh;
    width: 70vw;
}

.l_box1 {
    height: 150px;
}

.l_row {
    line-height: 20px;
    width: 173px;
}

.l_row text {
    height: 20px;
}

.fotBtn {
    background: #fff;
    border-top: 1px solid #f0f1f5;
    color: var(--themeColor);
    font-size: 36rpx;
    height: 113rpx;
    line-height: 113rpx;
    position: relative;
    text-align: center;
    width: 100%;
    z-index: 99;
}

.p {
    text-align: left;
    text-indent: 2em;
}

.bottom {
    color: #999;
    margin-bottom: 10px;
    margin-top: 10px;
    text-align: center;
}

