page {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
}

.visitor {
    background: #fff;
    flex-shrink: 0;
    height: 100rpx;
    padding: 0 24rpx;
}

.visitor .info {
    font-size: 34rpx;
}

.visitor .info image {
    border-radius: 50%;
    height: 60rpx;
    width: 60rpx;
}

.visitor .info .name {
    margin-left: 20rpx;
}

.visitor .info .card {
    color: #14c79d;
    margin-left: 10rpx;
}

.visitor .select {
    border: 2rpx solid #14c79d;
    border-radius: 5rpx;
    color: #14c79d;
    height: 44rpx;
    line-height: 44rpx;
    text-align: center;
    width: 94rpx;
}

.header {
    align-items: flex-end;
    flex-shrink: 0;
    height: 90rpx;
}

.header .title_select {
    border: 2rpx solid #14c79d;
    border-radius: 10rpx;
    height: 66rpx;
    overflow: hidden;
    width: 528rpx;
}

.header .title_select .item {
    align-items: center;
    color: #14c79d;
    display: -webkit-flex;
    display: flex;
    flex: 1;
    justify-content: center;
}

.header .title_select .active {
    background: #14c79d;
    color: #fff;
}

.section {
    box-sizing: border-box;
    padding: 0 24rpx 100rpx;
}

.section .item {
    background: #fff;
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 260rpx;
    margin-bottom: 20rpx;
}

.section .item:first-child {
    margin-top: 20rpx;
}

.section .item .i-top {
    border-bottom: 1rpx solid #ebebeb;
    height: 100rpx;
    padding-left: 30rpx;
}

.section .item .i-top text {
    font-size: 34rpx;
    margin-left: 10rpx;
}

.section .item .i-bot .info {
    color: #4c4c4c;
    display: -webkit-flex;
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: center;
    padding-left: 30rpx;
}

.section .item .i-bot .info text:first-child {
    font-size: 28rpx;
    margin-bottom: 24rpx;
}

checkbox .checkbox-input {
    border-radius: 50%;
    height: 36rpx;
    width: 36rpx;
}

checkbox .checkbox-input.checkbox-input-checked {
    background: #14c79d;
    border-color: transparent;
}

checkbox .checkbox-input.checkbox-input-checked::before {
    background: transparent;
    border-radius: 50%;
    color: #fff;
    font-size: 28rpx;
    height: 36rpx;
    line-height: 36rpx;
    text-align: center;
    transform: translate(-50%,-50%) scale(1);
    width: 36rpx;
}

.footer {
    background: #fff;
    bottom: 0;
    height: 100rpx;
    position: fixed;
    width: 100%;
}

.footer .allselect {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    padding-left: 24rpx;
}

.footer .allselect text {
    color: #4c4c4c;
    font-size: 32rpx;
    margin-left: 20rpx;
}

.footer .btn {
    background: #14c79d;
    color: #fff;
    font-size: 34rpx;
    line-height: 100rpx;
    text-align: center;
    width: 260rpx;
}

