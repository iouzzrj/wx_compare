.bgroud {
    background: #16c79d;
    height: 400rpx;
    left: 0;
    position: absolute;
    top: 0;
    width: 100%;
    z-index: -1;
}

.image {
    display: block;
    height: 125rpx;
    margin: 50rpx auto 0;
    width: 162rpx;
}

.box {
    overflow: hidden;
}

.explain1 {
    color: #fff;
    font-size: 36rpx;
    font-weight: 700;
    margin-bottom: 20rpx;
    margin-top: 32rpx;
    text-align: center;
}

.explain2 {
    display: block;
    margin-bottom: 20rpx;
    width: 100%;
}

.explain2,.explain3 {
    color: #fff;
    font-size: 28rpx;
    margin-top: 10rpx;
    text-align: center;
}

.explain3 {
    margin-bottom: 30rpx;
}

.infoBox {
    background: #fff;
    border-radius: 16rpx;
    box-sizing: border-box;
    margin: 0 auto 20rpx;
    padding: 30rpx;
    width: 690rpx;
}

.btnBox {
    align-items: center;
    background: #fff;
    display: -webkit-flex;
    display: flex;
    height: 150rpx;
    justify-content: center;
    width: 100%;
}

.btn {
    background: #16c79d;
    border-radius: 8rpx;
    color: #fff;
    font-size: 36rpx;
    font-weight: 700;
    height: 90rpx;
    line-height: 90rpx;
    opacity: 1;
    text-align: center;
    width: 690rpx;
}

.btnnot {
    opacity: .6;
}

.item {
    border-bottom: 1px solid #eee;
    box-sizing: border-box;
    margin-top: 30rpx;
    padding-bottom: 14rpx;
}

.item view {
    color: #1a1a1a;
    font-size: 30rpx;
}

.iptbox {
    margin-top: 20rpx;
}

.ipt {
    color: #1a1a1a;
    font-size: 30rpx;
}

.placetext {
    color: #b3b3b3;
    font-size: 30rpx;
    font-weight: 400!important;
}

.picker_box {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
    margin-top: 20rpx;
}

.picker_box view {
    color: #1a1a1a;
    font-size: 30rpx;
}

.picker_box text {
    color: #b3b3b3;
    font-size: 30rpx;
    font-weight: 400!important;
}

.picker_box image {
    height: 16rpx;
    transform: rotate(180deg);
    width: 25rpx;
}

.phonebtn {
    background: #fff;
    color: #b3b3b3;
    font-size: 30rpx;
    height: 34rpx;
    line-height: 34rpx;
    margin: 0rpx;
    padding-left: 0rpx;
    padding-right: 0rpx;
    text-align: start;
}

.scroll {
    flex: 1;
    overflow: hidden!important;
}

.oPage {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100%;
}

.contents {
    color: var(--jc_red);
    font-size: 30rpx;
}

