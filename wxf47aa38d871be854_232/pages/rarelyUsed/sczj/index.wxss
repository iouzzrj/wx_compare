.top {
    background: #f3f4f6;
    height: 20rpx;
    width: 100%;
}

.oBox {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: 100vh;
    width: 100%;
}

.scroll {
    background-color: #fff;
    box-sizing: border-box;
    flex: 1;
    overflow: hidden!important;
}

.oBox_ts1 {
    color: #1a1a1a;
    font-size: 36rpx;
    font-weight: 700;
    margin: 14rpx 0;
}

.oBox_ts2 {
    color: #ff944c;
    font-size: 28rpx;
    line-height: 48rpx;
}

.uploading {
    margin-top: 50rpx;
}

.uploading image {
    display: block;
    height: 388rpx;
    margin: auto;
    width: 690rpx;
}

.uploading view {
    color: #333;
    font-size: 28rpx;
    font-weight: 500;
    margin-top: 30rpx;
    text-align: center;
}

.uploading view text {
    color: #16c79d;
}

.gfbox {
    border-top: 1rpx solid #eee;
    box-sizing: border-box;
    margin-top: 50rpx;
    overflow: hidden;
    padding-top: 26rpx;
    width: 100%;
}

.gfbox_top {
    color: #333;
    font-size: 32rpx;
    font-weight: 500;
}

.psxzgf {
    justify-content: space-between;
    margin-bottom: 40rpx;
    margin-top: 26rpx;
}

.psxzgf,.psxzgf view {
    align-items: center;
    display: -webkit-flex;
    display: flex;
}

.psxzgf view {
    flex-direction: column;
}

.psxzgf view image {
    height: 123rpx;
    margin-bottom: 16rpx;
    width: 150rpx;
}

.psxzgf view text {
    color: #666;
    font-size: 24rpx;
    font-weight: 500;
}

.agreement {
    padding: 20rpx;
}

.agreement navigator {
    color: #13ba84;
    display: inline;
    font-size: 30rpx;
}

.btn {
    background: #16c79d;
    border-radius: 8rpx;
    color: #fff;
    height: 90rpx;
    line-height: 90rpx;
    margin: 0 auto 30rpx;
    opacity: .6;
    text-align: center;
    width: 690rpx;
}

.isact {
    opacity: 1;
}

.btnbox {
    background-color: #fff;
}

