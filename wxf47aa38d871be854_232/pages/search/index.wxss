page {
    box-sizing: border-box;
    padding: 20rpx 24rpx 0;
}

.search_box {
    background: #fff;
    border: 1rpx solid #d4d4d4;
    border-radius: 10rpx;
    height: 78rpx;
    padding: 0 30rpx;
}

.search_box image {
    height: 34rpx;
    margin-right: 20rpx;
    width: 34rpx;
}

.txt_color {
    color: #999;
}

.grade {
    background: #fff;
    border: 1rpx solid #d4d4d4;
    margin-top: 20rpx;
}

.grade .label_title {
    border-bottom: 1rpx solid #ebebeb;
    height: 80rpx;
    padding: 0 30rpx;
}

.grade .label_title .lately {
    height: 34rpx;
    margin-right: 16rpx;
    width: 34rpx;
}

.grade .label_title .hot {
    height: 36rpx;
    margin-right: 16rpx;
    width: 28rpx;
}

.grade .label {
    display: -webkit-flex;
    display: flex;
    flex-wrap: wrap;
    justify-content: flex-start;
    padding: 36rpx 30rpx 0;
}

.grade .label text {
    border: 1rpx solid #ccc;
    border-radius: 8rpx;
    color: #4c4c4c;
    font-size: 28rpx;
    line-height: 56rpx;
    margin-bottom: 28rpx;
    margin-right: 28rpx;
    padding: 0 14rpx;
}

.grade .label text:last-child {
    margin-bottom: 36rpx;
}

