.container {
    flex-direction: column;
    height: 100%;
    width: 100%;
}

.container,.top {
    display: -webkit-flex;
    display: flex;
}

.top {
    align-items: center;
    background: #fff;
    height: 72rpx;
    justify-content: space-between;
    padding: 0 24rpx;
}

.top .t_txt_1 {
    color: red;
    font-size: 34rpx;
}

.top .t_txt_2 {
    font-size: 26rpx;
}

.top .t_txt_2 text {
    color: red;
}

.wrap {
    background: #fff;
    margin-top: 12rpx;
    padding: 30rpx 24rpx;
}

.wrap,.wrap .row {
    box-sizing: border-box;
}

.wrap .row {
    font-size: 28rpx;
    padding-bottom: 46rpx;
}

.wrap .row .txt_1 {
    color: #343434;
    line-height: 1;
}

.wrap .row .txt_2 {
    color: red;
}

.wrap .row .txt_2,.wrap .row .txt_3 {
    display: inline-block;
    line-height: 1;
    padding-left: 40rpx;
}

.wrap .row .txt_3 {
    color: #999;
}

.padding-bottom-none {
    padding-bottom: 0!important;
}

.wrap .inside {
    align-items: center;
    background-color: #f6f7fb;
    border-radius: 10rpx;
    box-sizing: border-box;
    display: -webkit-flex;
    display: flex;
    height: 133rpx;
    margin-top: 24rpx;
    padding: 0 30rpx;
}

.wrap .inside image {
    border-radius: 50%;
    height: 106rpx;
    margin-right: 46rpx;
    width: 106rpx;
}

.wrap .inside .w_box {
    display: -webkit-flex;
    display: flex;
    margin-bottom: 20rpx;
}

.wrap .inside .inside_txt_1 {
    color: #262626;
    font-size: 32rpx;
}

.wrap .inside .inside_txt_2 {
    align-self: flex-end;
    color: #999;
    font-size: 24rpx;
    margin-left: 14rpx;
}

.wrap .inside .inside_txt_3 {
    color: #999;
    font-size: 28rpx;
}

.footer_wrap {
    background: #fff;
    box-sizing: border-box;
    flex: 1;
    margin-top: 12rpx;
    padding-top: 20rpx;
}

.footer {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    justify-content: space-between;
    padding: 0 24rpx;
}

.footer .btn_1 {
    background: #fff;
    color: #14c79d;
}

.footer .btn_1,.footer .btn_2 {
    border: 2rpx solid #14c79d;
    border-radius: 10rpx;
    height: 81rpx;
    line-height: 81rpx;
    position: relative;
    text-align: center;
    width: 337rpx;
}

.footer .btn_2 {
    background-color: #14c79d;
    color: #fff;
}

.footer .btn_1 button,.footer .btn_2 button {
    height: 100%;
    left: 0;
    opacity: 0;
    position: absolute;
    top: 0;
    width: 100%;
    z-index: 99;
}

.dy-tips {
    background: rgba(51,51,51,.8);
    bottom: 0;
    left: 0;
    overflow: hidden;
    padding-top: 100rpx;
    position: fixed;
    right: 0;
    text-align: center;
    top: 0;
    z-index: 99999;
}

.dy-tips image {
    width: 648rpx;
}

.dy-tips .dy-btn {
    background-color: red;
    height: 120rpx;
    left: 0;
    margin: 0 auto;
    opacity: 0;
    position: absolute;
    right: 0;
    top: 805rpx;
    width: 240rpx;
}

