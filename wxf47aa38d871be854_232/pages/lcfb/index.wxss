page {
    box-sizing: border-box;
    padding-top: 20rpx;
}

.section {
    align-items: center;
    display: -webkit-flex;
    display: flex;
    flex-direction: row;
    justify-content: center;
}

.section .hd_wrap {
    background-color: #f7f7f7;
    width: 80rpx;
}

.section .hd_wrap .hd_item {
    border-left: 6rpx solid #f7f7f7;
    padding: 20rpx 10rpx;
}

.section .hd_wrap .hd_item text {
    color: #999;
    display: block;
    font-size: 30rpx;
    letter-spacing: 10rpx;
    white-space: nowrap;
    writing-mode: vertical-lr;
}

.section .hd_wrap .hd_item.selected {
    background-color: #fff;
    border-left: 6rpx solid #14c79d;
}

.section .hd_wrap .hd_item.selected text {
    color: #14c79d;
}

.section .bd_wrap {
    background-color: #fff;
    flex: 1;
    padding: 0 20rpx;
}

.section .bd_wrap .list_cell {
    padding: 20rpx 0;
}

.section .bd_wrap .list_cell .title {
    padding: 10rpx 0;
}

.section .bd_wrap .list_cell .title text {
    color: #404040;
    font-size: 30rpx;
    font-weight: 700;
}

.section .bd_wrap .list_cell .content.table .tb_row {
    align-items: center;
    border-left: 1rpx solid #ccc;
    border-right: 1rpx solid #ccc;
    border-top: 1rpx solid #ccc;
    display: -webkit-flex;
    display: flex;
    flex-direction: row;
    justify-content: center;
}

.section .bd_wrap .list_cell .content.table .tb_row:last-child {
    border-bottom: 1rpx solid #ccc;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell {
    padding: 10rpx;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell:nth-child(1) {
    text-align: center;
    width: 55rpx;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell:nth-child(2) {
    border-left: 1rpx solid #ccc;
    flex: 1;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell:nth-child(1) text {
    color: #404040;
    font-size: 30rpx;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell:nth-child(2) text {
    color: #404040;
    display: inline-block;
    font-size: 30rpx;
    margin-right: 20rpx;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell:nth-child(2) text:last-child {
    margin-right: 0;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell.cell_row {
    padding: 0;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell.none {
    padding: 0;
    width: 0;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell.none_border {
    border-left: 0;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell.cell_row .tb_row {
    border: 0;
    border-bottom: 1rpx solid #ccc;
}

.section .bd_wrap .list_cell .content.table .tb_row .tb_cell.cell_row .tb_row:last-child {
    border-bottom: 0;
}

.section .bd_wrap .placeholder {
    visibility: hidden;
}

