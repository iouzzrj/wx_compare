.oBody {
    display: -webkit-flex;
    display: flex;
    flex-direction: column;
    height: calc(100vh - 90rpx);
    width: 100%;
}

.bodyList {
    z-index: 9;
}

.bodyList,.noDataBox {
    flex: 1;
    overflow: hidden;
}

.visitor {
    background: #fff;
    box-sizing: border-box;
    height: 100rpx;
    left: 0;
    padding: 0 12rpx;
    position: fixed;
    right: 0;
    top: 0;
    z-index: 999;
}

.visitor .info {
    font-size: 34rpx;
}

.visitor .info image {
    border-radius: 50%;
    height: 60rpx;
    width: 60rpx;
}

.visitor .info .name {
    margin-left: 20rpx;
}

.visitor .info .card {
    color: #14c79d;
    margin-left: 10rpx;
}

.visitor .select {
    border: 2rpx solid #14c79d;
    border-radius: 5rpx;
    color: #14c79d;
    height: 44rpx;
    line-height: 44rpx;
    text-align: center;
    width: 170rpx;
}

.section {
    box-sizing: border-box;
    padding: 12rpx 12rpx 0;
}

.section .item {
    background: #fff;
    margin-bottom: 20rpx;
}

.section .item .title {
    border-bottom: 1px solid #ebebeb;
    height: 100rpx;
    padding-left: 30rpx;
}

.section .item .title text {
    font-size: 34rpx;
    font-weight: 700;
}

.section .item .title view {
    border-bottom-left-radius: 30rpx;
    border-top-left-radius: 30rpx;
    color: #fff;
    font-size: 32rpx;
    height: 60rpx;
    line-height: 60rpx;
    text-indent: 40rpx;
    width: 200rpx;
}

.section .item .title .red {
    background: #ff625b;
}

.section .item .title .green {
    background: #14c79d;
}

.section .item .title .gray {
    background: #d7d9d9;
}

.section .item .detail {
    border-bottom: 1px solid #ebebeb;
    padding: 0 30rpx;
}

.section .item .detail .d_box {
    border-left: 3rpx solid #14c79d;
}

.section .item .detail .d_box .row {
    color: #4c4c4c;
    font-size: 32rpx;
    padding-left: 24rpx;
    padding-top: 30rpx;
    position: relative;
}

.section .item .detail .d_box .row:nth-child(1) {
    padding-top: 40rpx;
}

.section .item .detail .d_box .row:last-child {
    padding-bottom: 30rpx;
}

.section .item .detail .d_box .row .round {
    background: #14c79d;
    border-radius: 50%;
    height: 20rpx;
    left: -10rpx;
    position: absolute;
    width: 20rpx;
}

.section .item .detail .d_box .row .r_1 {
    top: 52rpx;
}

.section .item .detail .d_box .row .r_2,.section .item .detail .d_box .row .r_3 {
    top: 42rpx;
}

.section .item .detail .d_box .row .info {
    background: #ebebeb;
    display: -webkit-flex;
    display: flex;
    flex: 1;
    flex-direction: column;
    font-size: 28rpx;
    height: 100rpx;
    justify-content: center;
    padding-left: 20rpx;
}

.section .item .detail .d_box .row .info text:first-child {
    margin-bottom: 6rpx;
}

.section .item .select {
    height: 110rpx;
}

.section .item .select text {
    border-radius: 8rpx;
    font-size: 32rpx;
    line-height: 70rpx;
    margin: 0 30rpx;
    text-align: center;
    width: 226rpx;
}

.section .item .select .left {
    border: 1px solid #ff625b;
    color: #ff625b;
}

.section .item .select .right {
    border: 1px solid #14c79d;
    color: #14c79d;
}

.tip_txt {
    padding: 12rpx 12rpx 0rpx;
}

.tip_txt text {
    background: #fc837e;
    border-radius: 10rpx;
    color: #fff;
    display: block;
    font-family: 微软雅黑;
    font-size: 28rpx;
    line-height: 1.8;
    padding: 6px;
    text-align: justify;
    text-indent: 2em;
}

.select-box {
    background-color: #f0f5f4;
    padding: 12rpx 12rpx 0;
}

.select-box>view {
    background-color: #fff;
    display: -webkit-flex;
    display: flex;
    height: 88rpx;
    justify-content: space-around;
}

.select-box.l_fixed {
    left: 0;
    position: fixed;
    right: 0;
    top: 100rpx;
    z-index: 999;
}

.select-box text {
    border-bottom: 2rpx solid #fff;
    box-sizing: border-box;
    color: #666;
    font-size: 30rpx;
    height: 88rpx;
    line-height: 88rpx;
    padding: 0 8rpx;
}

.select-box .active {
    border-bottom: 6rpx solid #14c79d;
    color: #14c79d;
    font-weight: 700;
}

.dy-tips {
    background: rgba(51,51,51,.8);
    bottom: 0;
    left: 0;
    overflow: hidden;
    padding-top: 100rpx;
    position: fixed;
    right: 0;
    text-align: center;
    top: 0;
    z-index: 99999;
}

.dy-tips image {
    width: 648rpx;
}

.dy-tips .dy-btn {
    background-color: red;
    height: 120rpx;
    left: 0;
    margin: 0 auto;
    opacity: 0;
    position: absolute;
    right: 0;
    top: 850rpx;
    width: 240rpx;
}

.txt_box {
    flex: 1;
}

.payTitle {
    color: #fc837e;
    height: 27px;
    text-align: center;
}

